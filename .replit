modules = ["nodejs-20", "nix"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 3000
externalPort = 80

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git reset --hard origin/main; fuser -k 3000/tcp 2>/dev/null || true; npm install --prefer-offline 2>/dev/null || npm install; npm run dev"
